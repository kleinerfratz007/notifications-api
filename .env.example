# Notifications-API — Production Secrets
# Datei NIEMALS committen. Auf dem Hetzner-Server liegt sie unter /root/id-portal/api/.env
# Nach Anlage: chmod 600 .env

# Encryption key für gespeicherte API-Configs (api_config.value)
# Generieren: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=

# Service-Token für Admin-Operationen auf api_config (CONFIG_SERVICE_TOKEN check)
# Generieren: openssl rand -hex 32
CONFIG_SERVICE_TOKEN=

# Inter-App-Inbox Bearer-Token (Konvention #8)
# Muss in JEDER App identisch sein, die /api/notifications/send aufruft
# Generieren: openssl rand -hex 32
NOTIFICATIONS_SERVICE_TOKEN=

# SMTP — urlaub@id-engineering-portal.com auf Hetzner Mail (www684.your-server.de)
MAIL_PASSWORD=

# Optional: Override gegen Defaults aus ecosystem.config.js
# MAIL_HOST=www684.your-server.de
# MAIL_PORT=587
# MAIL_FROM=urlaub@id-engineering-portal.com
# MAIL_WHITELIST=sartor.m@id-engineering.com
